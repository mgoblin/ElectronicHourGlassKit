<?xml version="1.0" encoding="UTF-8"?>
<CONFIG>
  <ProjectOptions>
    <Version Value="12"/>
    <General>
      <SessionStorage Value="InProjectDir"/>
      <Title Value="led_unittests"/>
      <ResourceType Value="res"/>
      <UseXPManifest Value="True"/>
      <XPManifest>
        <ExecutionLevel Value="requireAdministrator"/>
      </XPManifest>
      <Icon Value="0"/>
    </General>
    <MacroValues Count="1">
      <Macro1 Name="LCLWidgetType" Value="gtk2"/>
    </MacroValues>
    <BuildModes>
      <Item Name="Default" Default="True"/>
      <SharedMatrixOptions Count="1">
        <Item1 ID="197572194259" Modes="Default" Type="IDEMacro" MacroName="LCLWidgetType" Value="gtk2"/>
      </SharedMatrixOptions>
    </BuildModes>
    <PublishOptions>
      <Version Value="2"/>
      <UseFileFilters Value="True"/>
    </PublishOptions>
    <RunParams>
      <FormatVersion Value="2"/>
    </RunParams>
    <RequiredPackages>
      <Item>
        <PackageName Value="LedControl"/>
      </Item>
      <Item>
        <PackageName Value="fpcunittestrunner"/>
      </Item>
      <Item>
        <PackageName Value="LCL"/>
      </Item>
      <Item>
        <PackageName Value="FCL"/>
      </Item>
    </RequiredPackages>
    <Units>
      <Unit>
        <Filename Value="led_unittests.lpr"/>
        <IsPartOfProject Value="True"/>
      </Unit>
      <Unit>
        <Filename Value="simplifiedledclicktestcase.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="SimplifiedLedClickTestCase"/>
      </Unit>
      <Unit>
        <Filename Value="simplifiedledconstructortestcase.pas"/>
        <IsPartOfProject Value="True"/>
        <UnitName Value="SimplifiedLedConstructorTestCase"/>
      </Unit>
    </Units>
  </ProjectOptions>
  <CompilerOptions>
    <Version Value="11"/>
    <Target>
      <Filename Value="led_unittests"/>
    </Target>
    <SearchPaths>
      <IncludeFiles Value="$(ProjOutDir)"/>
      <OtherUnitFiles Value="."/>
      <UnitOutputDirectory Value="lib/$(TargetCPU)-$(TargetOS)"/>
    </SearchPaths>
    <Linking>
      <Debugging>
        <DebugInfoType Value="dsDwarf3"/>
      </Debugging>
      <Options>
        <Win32>
          <GraphicApplication Value="True"/>
        </Win32>
      </Options>
    </Linking>
    <Other>
      <CustomOptions Value="-gv -gl"/>
    </Other>
  </CompilerOptions>
  <Debugging>
    <Exceptions>
      <Item>
        <Name Value="EAbort"/>
      </Item>
      <Item>
        <Name Value="ECodetoolError"/>
      </Item>
      <Item>
        <Name Value="EFOpenError"/>
      </Item>
    </Exceptions>
  </Debugging>
</CONFIG>
